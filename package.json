{
  "name": "trajectiv",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@11.7.0",
  "workspaces": [
    "projects/keycloak-theme"
  ],
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "build:keycloak-theme": "npm --workspace projects/keycloak-theme run build-keycloak-theme",
    "copy:keycloak-theme": "powershell -ExecutionPolicy Bypass -Command \"Copy-Item projects/keycloak-theme/dist_keycloak/keycloak-theme-for-kc-all-other-versions.jar docker/keycloak/providers/trajectiv-theme.jar -Force\"",
    "deploy:keycloak-theme": "npm run build:keycloak-theme && npm run copy:keycloak-theme"
  },
  "dependencies": {
    "@angular-architects/ngrx-toolkit": "^21.0.1",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@fontsource/geist": "^5.2.9",
    "@ngrx/signals": "^21.1.0",
    "@primeuix/themes": "^2.0.3",
    "keycloak-angular": "^21.0.0",
    "keycloak-js": "^26.2.4",
    "leaflet": "^1.9.4",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.8",
    "rxjs": "~7.8.0",
    "tailwindcss-primeui": "^0.6.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.13",
    "@angular/cli": "^21.2.13",
    "@angular/compiler-cli": "^21.2.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/leaflet": "^1",
    "jsdom": "^28.0.0",
    "ng-packagr": "^21.2.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
