/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve",
    "paths": {
      "@app/*": ["./projects/app/*"],
      "@features/*": ["./projects/app/src/app/features/*"],
      "@shared/*": ["./projects/app/src/app/shared/*"],
      "@i18n/*": ["./projects/i18n/*"],
      "@themes/*": ["./projects/themes/*"],
      "@shared-ui": ["./projects/shared-ui/src/public-api.ts"],
      "@core": ["./projects/core/src/public-api.ts"],
      "@env": ["./projects/app/src/environments"],
      "@shared-domain": ["./projects/shared-domain/src/public-api.ts"],
      "@shared-domain/*": ["./projects/shared-domain/src/lib/*"],
      "@shared-api-client": ["./projects/shared-api-client/src/public-api.ts"],
      "@shared-api-client/*": ["./projects/shared-api-client/src/generated/*"],
      "@shared-data-access": ["./projects/shared-data-access/src/public-api.ts"],
      "@shared-data-access/*": ["./projects/shared-data-access/src/lib/*"]
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  },
  "files": [],
  "references": [
    {
      "path": "./projects/app/tsconfig.app.json"
    },
    {
      "path": "./projects/app/tsconfig.spec.json"
    },
    {
      "path": "./projects/shared-ui/tsconfig.lib.json"
    },
    {
      "path": "./projects/shared-ui/tsconfig.spec.json"
    },
    {
      "path": "./projects/core/tsconfig.lib.json"
    },
    {
      "path": "./projects/core/tsconfig.spec.json"
    },
    {
      "path": "./projects/shared-domain/tsconfig.lib.json"
    },
    {
      "path": "./projects/shared-domain/tsconfig.spec.json"
    },
    {
      "path": "./projects/shared-api-client/tsconfig.lib.json"
    },
    {
      "path": "./projects/shared-api-client/tsconfig.spec.json"
    },
    {
      "path": "./projects/shared-data-access/tsconfig.lib.json"
    },
    {
      "path": "./projects/shared-data-access/tsconfig.spec.json"
    }
  ]
}
